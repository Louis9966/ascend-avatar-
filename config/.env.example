# ascend-avatar environment configuration
# Copy to .env and fill in real values

# LLM (OpenAI-compatible)
# 本地 MindIE 服务不需要 API Key；若使用外部端点请填写。
LLM_API_KEY=
LLM_BASE_URL=http://192.168.1.117:1025/v1
LLM_MODEL=qwen3_32b

# Ascend NPU
# In the container only /dev/davinci7 is visible; torch_npu sees it as device 0.
ASCEND_NPU_DEVICE=npu:0

# Application paths (inside container)
PROJECT_ROOT=/ascend-avatar
AVATAR_DIR=/ascend-avatar/avatars
VOICE_DIR=/ascend-avatar/voices
OUTPUT_DIR=/ascend-avatar/output
THG_DIR=/ascend-avatar/thg
TTS_DIR=/ascend-avatar/tts
UPLOAD_DIR=/ascend-avatar/uploads
GENERATED_DIR=/ascend-avatar/output/generated

# MuseTalk / THG
MUSE_TALK_VERSION=v15
MUSE_TALK_MODEL_DIR=/ascend-avatar/thg/models
MUSE_TALK_BATCH_SIZE=8
MUSE_TALK_FPS=25
MUSE_TALK_BBOX_SHIFT=0
AVATAR_ID=default

# MuseTalk video quality tuning (Phase 9/10)
# THG_BLUR_RATIO: lower = sharper mouth edges, but too low may show mask seams
# THG_PREPARE_RESOLUTION: e.g. 512x512 to center-crop/scale avatar input before prepare;
#                          leave empty to use the original resolution
THG_EXTRA_MARGIN=10
THG_PARSING_MODE=jaw
THG_LEFT_CHEEK_WIDTH=90
THG_RIGHT_CHEEK_WIDTH=90
THG_UPPER_BOUNDARY_RATIO=0.5
THG_EXPAND=1.5
THG_BLUR_RATIO=0.03
THG_RENDER_INTERPOLATION=lanczos4
THG_PREPARE_RESOLUTION=
FFMPEG_CRF=18
FFMPEG_PRESET=medium

# Optional GFPGAN post-processing for video generation mode
#VIDEO_GEN_POSTPROCESS_GFPGAN=true
#GFPGAN_MODEL_PATH=/ascend-avatar/thg/models/gfpgan/GFPGANv1.4.pth
#GFPGAN_UPSCALE=1        # 1 keeps input resolution, 2 upsamples then downscales
#GFPGAN_ARCH=clean
#GFPGAN_CHANNEL_MULTIPLIER=2
#GFPGAN_DEVICE=npu   # use "npu" to run on Ascend 910B (requires torch_npu)

# MediaPipe mouth bbox margins (relative to lip span). Increase for more
# cheek/chin context; decrease for a tighter mouth crop.
#MEDIAPIPE_MOUTH_MARGIN_X=0.6
#MEDIAPIPE_MOUTH_MARGIN_Y=0.6
# Temporal smoothing window for the detected mouth crop (frames).  Larger is
# smoother but adds a small delay; 5 is a good default.
#MEDIAPIPE_SMOOTHING_WINDOW=5

# TTS (real-time chat mode)
TTS_VOICE_ZH_FEMALE=zh-CN-XiaoxiaoNeural
TTS_VOICE_ZH_MALE=zh-CN-YunxiNeural
TTS_VOICE_EN=zh-CN-YunxiNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# Video generation mode TTS (PaddleSpeech)
VIDEO_GEN_TTS_ENGINE=paddlespeech
VIDEO_GEN_FALLBACK_TTS=true
PADDLESPEECH_AM=fastspeech2_aishell3
PADDLESPEECH_VOC=hifigan_aishell3
PADDLESPEECH_LANG=zh
PADDLESPEECH_SPK_ID=0
PADDLESPEECH_DEVICE=cpu

# Upload / avatar cache
MAX_UPLOAD_DURATION_S=30
MAX_UPLOAD_SIZE_MB=200
AVATAR_CACHE_SIZE=5

# Media server (mediamtx)
MEDIAMTX_PATH=/ascend-avatar/bin/mediamtx
MEDIAMTX_CONFIG=/ascend-avatar/config/mediamtx.yml
MEDIAMTX_HOST=127.0.0.1
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_WEBRTC_PORT=8889

# Web UI
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8188

# Logging
LOG_LEVEL=INFO
